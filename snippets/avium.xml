<?xml version="1.0" encoding="UTF-8"?>
<manifest>

<remote name="avium"
        fetch="https://github.com/AviumUI"
        sync-c="true"
        sync-j="4"
        revision="refs/heads/avium-16" />

    <project path="android" name="android_manifests" remote="avium" />

    <!-- Bootable -->
    <project path="bootable/recovery" name="android_bootable_recovery" groups="pdk" remote="avium" />

    <!-- Build -->
    <project path="build/make" name="android_build" groups="pdk,sysui-studio" remote="avium" >
        <linkfile src="CleanSpec.mk" dest="build/CleanSpec.mk" />
        <linkfile src="buildspec.mk.default" dest="build/buildspec.mk.default" />
        <linkfile src="core" dest="build/core" />
        <linkfile src="envsetup.sh" dest="build/envsetup.sh" />
        <linkfile src="target" dest="build/target" />
        <linkfile src="tools" dest="build/tools" />
    </project>

    <project path="build/soong" name="android_build_soong" groups="pdk,tradefed" remote="avium" >
        <linkfile src="root.bp" dest="Android.bp" />
        <linkfile src="bootstrap.bash" dest="bootstrap.bash" />
    </project>

    <!-- Device -->
    <project path="device/lineage/sepolicy" name="android_device_lineage_sepolicy"  remote="avium" />

    <!-- Frameworks -->
    <project path="frameworks/av" name="android_frameworks_av" groups="pdk,sysui-studio" remote="avium" />
    <project path="frameworks/base" name="android_frameworks_base" groups="pdk-cw-fs,pdk-fs,sysui-studio" remote="avium" />
    <project path="frameworks/libs/systemui" name="android_frameworks_libs_systemui" groups="pdk-cw-fs,pdk-fs,sysui-studio" remote="avium" />
    <project path="frameworks/native" name="android_frameworks_native" groups="pdk" remote="avium" />

    <!-- Packages -->
    <project path="packages/apps/AviumSetup" name="packages_apps_AviumSetup" remote="avium" />
    <project path="packages/apps/AviumSystemUIEX" name="android_packages_apps_AviumSystemUIEX" remote="avium" />
    <project path="packages/apps/BtHelper" name="android_packages_apps_BtHelper" remote="avium" />
    <project path="packages/apps/CatShare" name="android_packages_apps_CatShare" remote="avium" />
    <project path="packages/apps/Launcher3" name="android_packages_apps_Launcher3" groups="pdk-fs,sysui-studio,pdk-cw-tvc" remote="avium" />
    <project path="packages/apps/Messaging" name="android_packages_apps_Messaging" groups="pdk-fs" remote="avium" />
    <project path="packages/apps/Settings" name="android_packages_apps_Settings" groups="pdk-fs,pdk-cw-tvc" remote="avium" />
    <project path="packages/apps/SetupWizard" name="android_packages_apps_SetupWizard" remote="avium" />
    <project path="packages/apps/Updater" name="android_packages_apps_Updater" remote="avium" />
    <project path="packages/apps/Via" name="android_packages_apps_Via" remote="avium" />
    <project path="packages/apps/MoonOCR" name="android_packages_apps_MoonOCR" remote="avium" />
    <project path="packages/apps/FeatureSettings" name="android_packages_apps_FeatureSettings" remote="avium" />
    <project path="packages/apps/MoonWidget" name="android_packages_apps_MoonWidget" remote="avium" />
    <project path="packages/apps/ExthmUseful" name="android_packages_apps_ExthmUseful" remote="avium" />
    <project path="packages/apps/SystemUITools" name="android_packages_apps_SystemUITools" remote="avium" />
    <project path="packages/apps/GameSpace" name="android_packages_apps_GameSpace" remote="avium" />
    <project path="packages/apps/AviumLockscreenEdit" name="android_packages_apps_AviumLockscreenEdit" remote="avium" />
    <project path="packages/modules/Nfc" name="android_packages_modules_Nfc" groups="apps_nfc,pdk-fs,pdk-cw-fs" remote="avium" />

    <!-- external -->
    <project path="external/blurview" name="android_external_blurview" remote="avium" />

    <!-- Vendor -->
    <project path="vendor/lineage" name="android_vendor_lineage" remote="avium" />
    <project path="vendor/avium" name="android_vendor_avium" remote="avium" />

</manifest>
